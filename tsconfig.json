{
  "compilerOptions": {
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ], // Targeting ESNext and web DOM
    "allowJs": true, // Allows JavaScript files alongside TypeScript
    "skipLibCheck": true, // Skips type checks for declaration files
    "strict": false, // Disables all strict type checking
    "noImplicitAny": false, // Allows 'any' type without explicit typing
    "strictNullChecks": false, // Disables strict null checks
    "noImplicitReturns": false, // Allows functions to return implicitly
    "noImplicitThis": false, // Allows 'this' to have implicit 'any' type
    "strictFunctionTypes": false, // Loosens function type checking
    "noEmit": true, // Disables file emitting (Next.js handles this)
    "esModuleInterop": true, // Better interop between ES modules and CommonJS
    "module": "esnext", // ESNext module system for modern JavaScript
    "moduleResolution": "bundler", // Uses bundler resolution (Webpack/Vite) for frontend
    "resolveJsonModule": true, // Allows importing JSON modules
    "isolatedModules": true, // Required by Next.js to transpile each file in isolation
    "jsx": "preserve", // Updated to "react-jsx" for React 17+ JSX transform support
    "incremental": true, // Enables incremental compilation for faster builds
    "plugins": [
      {
        "name": "next" // Plugin specific to Next.js
      }
    ],
    "baseUrl": "./src", // Sets the base path for non-relative imports
    "paths": {
      "@/*": [
        "./*" // Updated alias to map to `src/*` relative to the baseUrl
      ] // Path alias to simplify imports from `src/`
    }
  },
  "include": [
    "next-env.d.ts", // Includes Next.js-specific types
    "**/*.ts", // Includes all TypeScript files
    "**/*.tsx", // Includes all files with JSX/TSX
    ".next/types/**/*.ts", // Next.js types generated by Next.js
    "backend/routes/**/*.ts", // Includes backend route files
    "backend/models/**/*.ts", // Includes backend model files
    "frontend/app/context/**/*.ts" // Include for files in the context folder
, "src/app/pod/[id]"  ],
  "exclude": [
    "node_modules",
    ".next",
    "dist"
  ] // Excludes unnecessary folders
}
